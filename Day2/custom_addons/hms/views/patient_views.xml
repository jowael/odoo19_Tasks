<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- ===================== -->
    <!-- ACTION (IMPORTANT)    -->
    <!-- ===================== -->

    <record id="action_hms_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hms.patient</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- ===================== -->
    <!-- LIST VIEW             -->
    <!-- ===================== -->

    <record id="view_hms_patient_list" model="ir.ui.view">
        <field name="name">hms.patient.list</field>
        <field name="model">hms.patient</field>

        <field name="arch" type="xml">
            <list>
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="state"/>
                <field name="department_id"/>
                <field name="age"/>
            </list>
        </field>
    </record>


    <!-- ===================== -->
    <!-- FORM VIEW             -->
    <!-- ===================== -->

    <record id="view_hms_patient_form" model="ir.ui.view">
        <field name="name">hms.patient.form</field>
        <field name="model">hms.patient</field>

        <field name="arch" type="xml">
            <form>

                <sheet>

                    <!-- IMAGE -->
                    <group>
                        <field name="image"
                               widget="image"
                               class="oe_avatar"
                               nolabel="1"/>
                    </group>

                    <!-- BASIC INFO -->
                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="birth_date"/>
                            <field name="age" readonly="1"/>
                            <field name="state"/>
                        </group>

                        <group>
                            <field name="blood_type"/>
                            <field name="pcr"/>
                            <field name="cr_ratio" required="pcr"/>
                            <field name="department_id"/>
                            <field name="department_capacity" readonly="1"/>

                            <field name="doctor_ids"
                                   widget="many2many_tags"
                                   readonly="not department_id"/>
                        </group>
                    </group>

                    <!-- ADDRESS -->
                    <group>
                        <field name="address"/>
                    </group>

                    <!-- NOTEBOOK -->
                    <notebook>

                        <!-- HISTORY -->
                        <page string="History">
                            <field name="history"
                                   invisible="age &lt; 50"/>
                        </page>

                        <!-- LOGS -->
                        <page string="Logs">
                            <field name="log_ids">
                                <list>
                                    <field name="created_by"/>
                                    <field name="date"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

</odoo>