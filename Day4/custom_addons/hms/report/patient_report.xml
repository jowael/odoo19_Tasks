<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="patient_report_action"
            model="ir.actions.report">

        <field name="name">Patient Status Report</field>

        <field name="model">hms.patient</field>

        <field name="report_type">qweb-pdf</field>

        <field name="report_name">
            hms.patient_report_template
        </field>

        <field name="report_file">
            hms.patient_report_template
        </field>

    </record>

    <template id="patient_report_template">

        <t t-call="web.html_container">

            <t t-foreach="docs" t-as="o">

                <t t-call="web.external_layout">

                    <div class="page">

                        <h1 style="color:red;">
                            Patient Status Report
                        </h1>

                        <table style="width:100%;">

                            <tr>

                                <td>

                                    <p>
                                        <strong>Name:</strong>
                                        <span t-field="o.first_name"/>
                                        <span t-field="o.last_name"/>
                                    </p>

                                    <p>
                                        <strong>Age:</strong>
                                        <span t-field="o.age"/>
                                    </p>

                                    <p>
                                        <strong>Department:</strong>
                                        <span t-field="o.department_id"/>
                                    </p>

                                    <p>
                                        <strong>Doctors:</strong>

                                        <t t-foreach="o.doctor_ids"
                                           t-as="doc">

                                            <span t-field="doc.first_name"/>
                                            <span t-field="doc.last_name"/>,

                                        </t>

                                    </p>

                                </td>

                                <td>

                                    <img t-if="o.image"
                                         t-att-src="image_data_uri(o.image)"
                                         width="120"
                                         height="120"/>

                                    <p>
                                        <strong>Birth date:</strong>
                                        <span t-field="o.birth_date"/>
                                    </p>

                                    <p>
                                        <strong>PCR:</strong>
                                        <span t-field="o.cr_ratio"/>
                                    </p>

                                    <p>
                                        <strong>Blood Type:</strong>
                                        <span t-field="o.blood_type"/>
                                    </p>

                                    <p>
                                        <strong>Email:</strong>
                                        <span t-field="o.email"/>
                                    </p>

                                </td>

                            </tr>

                        </table>

                        <h2 style="color:red;text-align:center;">
                            Log History
                        </h2>

                        <table class="table table-bordered"
                               style="width:100%;">

                            <thead>

                                <tr>
                                    <th>User</th>
                                    <th>Date</th>
                                    <th>Info</th>
                                </tr>

                            </thead>

                            <tbody>

                                <tr t-foreach="o.log_ids"
                                    t-as="log">

                                    <td>
                                        <span t-field="log.created_by"/>
                                    </td>

                                    <td>
                                        <span t-field="log.date"/>
                                    </td>

                                    <td>
                                        <span t-field="log.description"/>
                                    </td>

                                </tr>

                            </tbody>

                        </table>

                    </div>

                </t>

            </t>

        </t>

    </template>

</odoo>